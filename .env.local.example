# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic (server-side only — never exposed to the client)
ANTHROPIC_API_KEY=

# Shared secret protecting /api/cron/* routes. Set the same value in Vercel
# env vars; Vercel Cron sends it as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# Optional — embeddings are off by default. To enable semantic RAG later,
# pick a provider and implement it in lib/embeddings.ts.
# EMBEDDINGS_PROVIDER=voyage
# VOYAGE_API_KEY=
# EMBEDDINGS_PROVIDER=openai
# OPENAI_API_KEY=
